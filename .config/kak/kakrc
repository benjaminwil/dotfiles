define-command source-conf -hidden -params 1 %{ source "%val{config}/%arg{@}.kak" }

# Load the KakScript files distributed with Kakoune.
evaluate-commands %sh{
    find -L "$kak_runtime/autoload" -name "*.kak" -exec \
        sh -c 'echo "try %{ source $1 } \
             catch %{ echo -debug cannot autoload $1 }"' _ {} \;
}

# On start, set up services and global utility commands.
hook global KakBegin .* %{
    source-conf start-services
    source-conf utility-commands

    source-conf window-commands
    set-option global windowing_placement "horizontal"

    load-local-config
}

# Match the system colorscheme (either dark or light).
hook global KakBegin .* %{ use-system-colorscheme }
hook global FocusIn .* %{ use-system-colorscheme }

# For each client, set the command used to open new terminals. (`termcmd`
# is not set in the scope of KakBegin.)
hook global ClientCreate .* %{ set-option global termcmd "ghostty -e sh -c" }

# Define the "ultra" user mode. I use this mode to bind often-used custom commands
# to common keys. These commands are accessed with the <space> key as a prefix.
hook global KakBegin .* %{
    declare-user-mode ultra

    map global normal <space> ":enter-user-mode ultra <ret>" \
       -docstring "Enter Ultra user mode."

    map global ultra B  ": buffer *<tab>"
    map global ultra b  ": buffer "
    map global ultra d  ": fetter popup fetter-nnn-from-buffile <ret>"
    map global ultra f  ": fetter vsplit fetter-rg-fzy <ret>"
    map global ultra g  ": fetter vsplit fetter-git-status-files-fzy <ret>"
    map global ultra q  "| fmt -w %opt{autowrap_column} <ret>"
    map global ultra m  ": fetter vsplit fetter-minitest-current-buffer <ret>"
    map global ultra S  ": fetter vsplit fetter-rspec-spec-under-cursor <ret>"
    map global ultra s  ": fetter vsplit fetter-rspec-current-buffer <ret>"
    map global ultra w  ": delete-buffer! <ret>"
    map global ultra ?  ": evaluate-commands %{ echo %val{buffile} } <ret>"
    map global ultra $  ": fetter terminal fetter-rspec <ret>"
}

# Set Kakoune UI options.
hook global KakBegin .* %{
    set-option -add global ui_options terminal_padding_char=;
    set-option -add global ui_options terminal_assistant=none
    set-option global idle_timeout 500
}

# Configure the Kakoune LSP for commonly used filetypes.
hook global WinSetOption filetype=(bash|c|cpp|go|haskell|python|ruby|sh|typescript|typescript.tsx) %{
    lsp-enable
    lsp-enable-window
    lsp-auto-hover-enable
}
hook -group lsp-filetype-ruby global BufSetOption filetype=ruby %{
    set-option buffer lsp_servers %{
        [ruby-lsp]
        root_globs = ["Gemfile"]
        args = ["stdio"]
    }
}

# Set common editor settings.
hook global KakBegin .* %{
    set-option global indentwidth 2
    set-option global scrolloff 3,6
    set-option global tabstop 2
}
hook global FocusOut ^[^.git].* %{ autosave-all-buffers }
hook global BufWritePre ^[^*].* %{ kill-trailing-whitespace }


# Configure autowrapping for paragraphs and add custom configuration for
# commonly used filetypes.
hook global KakBegin .* %{
    set-option global autowrap_fmtcmd "fmt -w %opt{autowrap_column}"
    set-option global autowrap_format_paragraph true
}
hook global WinSetOption filetype=(git-commit) %{
    set-option buffer autowrap_column 72
    autowrap-enable
}
hook global WinSetOption filetype=(markdown) %{
    set-option buffer autowrap_column 80
    autowrap-enable
}

# Hide line numbers by default for prose-like filetypes.
hook global WinSetOption \
    filetype=(?!git-commit)(?!markdown)(?!txt).* %{ line-numbers-show }
hook global WinSetOption \
    filetype=.{0} %{ line-numbers-hide }


# Configure the smarttab plugin for various commonly used filetypes.
hook global ModuleLoaded smarttab %{ set-option global softtabstop 2 }
hook global WinSetOption filetype=.* expandtab
hook global WinSetOption filetype=(makefile) smarttab
